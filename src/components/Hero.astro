---
import Section from "./Section.astro";
import { Icon } from "astro-icon/components";
import { siteData } from "../data/site";
---

<Section id="top" class="mt-16 md:mt-20">
  <h1 class="font-display text-4xl font-bold tracking-tight text-ink sm:text-5xl">
    {siteData.profile.name}
  </h1>
  <p class="mt-4 font-display text-xl text-accent sm:text-2xl">
    {siteData.profile.title}
  </p>
  <p class="mt-6 max-w-2xl text-base text-ink-soft">
    {siteData.profile.tagline}
  </p>
  <div class="mt-8 flex flex-wrap gap-4">
    <span class="cta-glow inline-flex rounded-full p-px">
      <a
        href="#experience"
        class="inline-flex items-center gap-1.5 rounded-full bg-accent px-5 py-2.5 text-sm font-semibold text-accent-ink transition hover:brightness-95"
        data-umami-event="cta-click"
        data-umami-event-cta="view-work"
      >
        View work
        <Icon name="tabler:arrow-down" class="h-4 w-4" />
      </a>
    </span>
    <a
      href={`mailto:${siteData.social.email}`}
      class="inline-flex items-center gap-1.5 rounded-full border border-line px-5 py-2.5 text-sm font-semibold text-ink transition hover:border-accent hover:text-accent"
      data-umami-event="email-click"
      data-umami-event-location="hero"
    >
      <Icon name="tabler:mail" class="h-4 w-4" />
      Get in touch
    </a>
    <div class="flex items-center gap-4 px-1 text-sm text-ink-soft">
      <a
        href={siteData.social.github}
        target="_blank"
        rel="noopener noreferrer me"
        aria-label="GitHub"
        class="transition hover:text-accent"
        data-umami-event="github-click"
        data-umami-event-location="hero"
      >
        <Icon name="tabler:brand-github" class="h-5 w-5" />
      </a>
      <a
        href={siteData.social.linkedin}
        target="_blank"
        rel="noopener noreferrer me"
        aria-label="LinkedIn"
        class="transition hover:text-accent"
        data-umami-event="linkedin-click"
        data-umami-event-location="hero"
      >
        <Icon name="tabler:brand-linkedin" class="h-5 w-5" />
      </a>
      <a
        href={siteData.social.malt}
        target="_blank"
        rel="noopener noreferrer me"
        aria-label="Malt"
        class="transition hover:text-accent"
        data-umami-event="malt-click"
        data-umami-event-location="hero"
      >
        <Icon name="simple-icons:malt" class="h-5 w-5" />
      </a>
    </div>
  </div>
</Section>

<style>
  @property --cta-angle {
    syntax: "<angle>";
    initial-value: 0deg;
    inherits: false;
  }

  .cta-glow {
    background: conic-gradient(
      from var(--cta-angle),
      transparent 0deg,
      transparent 305deg,
      transparent 315deg,
      color-mix(in srgb, var(--color-accent) 35%, white) 348deg,
      color-mix(in srgb, var(--color-accent) 45%, white) 352deg,
      transparent 356deg,
      transparent 360deg
    );
    animation: cta-rotate 7s linear infinite;
  }

  @keyframes cta-rotate {
    to {
      --cta-angle: 360deg;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-glow {
      animation: none;
    }
  }
</style>
