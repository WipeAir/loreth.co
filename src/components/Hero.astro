---
import Section from "./Section.astro";
import { siteData } from "../data/site";
---

<Section id="top" class="mt-9">
  <h1 class="font-display text-4xl font-bold tracking-tight text-ink sm:text-5xl">
    {siteData.profile.name}
  </h1>
  <p class="mt-4 font-display text-xl text-accent sm:text-2xl">
    {siteData.profile.title}
  </p>
  <p class="mt-6 max-w-2xl text-base text-ink-soft">
    {siteData.profile.tagline}
  </p>
  <div class="mt-8 flex flex-wrap gap-4">
    <span class="cta-glow inline-flex rounded-full p-px">
      <a
        href="#experience"
        class="rounded-full bg-accent px-5 py-2.5 text-sm font-semibold text-accent-ink transition hover:brightness-95"
        data-umami-event="cta-click"
        data-umami-event-cta="view-work"
      >
        View work
      </a>
    </span>
    <a
      href={`mailto:${siteData.social.email}`}
      class="rounded-full border border-line px-5 py-2.5 text-sm font-semibold text-ink transition hover:border-accent hover:text-accent"
      data-umami-event="email-click"
      data-umami-event-location="hero"
    >
      Get in touch
    </a>
  </div>
</Section>

<style>
  @property --cta-angle {
    syntax: "<angle>";
    initial-value: 0deg;
    inherits: false;
  }

  .cta-glow {
    background: conic-gradient(
      from var(--cta-angle),
      transparent 0deg,
      transparent 305deg,
      transparent 315deg,
      color-mix(in srgb, var(--color-accent) 35%, white) 348deg,
      color-mix(in srgb, var(--color-accent) 45%, white) 352deg,
      transparent 356deg,
      transparent 360deg
    );
    animation: cta-rotate 7s linear infinite;
  }

  @keyframes cta-rotate {
    to {
      --cta-angle: 360deg;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-glow {
      animation: none;
    }
  }
</style>
