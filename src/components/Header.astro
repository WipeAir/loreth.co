---
import Icon from "./Icon.astro";
import ThemeToggle from "./ThemeToggle.astro";
import { siteData } from "../data/site";
---

<header class="mx-auto max-w-7xl px-4 py-4 sm:px-8">
  <div class="mx-auto flex max-w-2xl items-center justify-end gap-4 lg:max-w-5xl lg:px-12">
    <a
      href={`mailto:${siteData.social.email}`}
      aria-label="Email"
      class="text-ink-soft transition hover:text-accent"
      data-umami-event="email-click"
      data-umami-event-location="header"
    >
      <Icon>
        <path d="M3 7a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7Z"></path>
        <path d="m3 7 9 6 9-6"></path>
      </Icon>
    </a>
    <a
      href={siteData.social.github}
      target="_blank"
      rel="noopener noreferrer me"
      aria-label="GitHub"
      class="text-ink-soft transition hover:text-accent"
      data-umami-event="github-click"
      data-umami-event-location="header"
    >
      <Icon>
        <path
          d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2 4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0C6.5 3.3 5.4 3.6 5.4 3.6a4.2 4.2 0 0 0-.1 3.2A4.6 4.6 0 0 0 4 10c0 4.6 2.7 5.7 5.5 6-.6.6-.6 1.2-.5 2V21"
        ></path>
      </Icon>
    </a>
    <a
      href={siteData.social.linkedin}
      target="_blank"
      rel="noopener noreferrer me"
      aria-label="LinkedIn"
      class="text-ink-soft transition hover:text-accent"
      data-umami-event="linkedin-click"
      data-umami-event-location="header"
    >
      <Icon>
        <path d="M8 11v5M8 8v.01M12 16v-5M16 16v-3a2 2 0 1 0-4 0"></path>
        <path d="M3 7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4v10a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V7Z"></path>
      </Icon>
    </a>
    <ThemeToggle />
  </div>
</header>
