---
import Card from "./Card.astro";
import Section from "./Section.astro";
import SectionHeading from "./SectionHeading.astro";
import { siteData } from "../data/site";
---

<Section id="projects">
  <SectionHeading>
    <h2 class="font-display text-2xl font-semibold tracking-tight text-ink">
      Projects
    </h2>
  </SectionHeading>
  <div class="mt-8 space-y-10">
    {siteData.projects.map((group) => (
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wide text-ink-soft">
          {group.label}
        </h3>
        <div class="mt-4 grid grid-cols-1 gap-6 sm:grid-cols-2">
          {group.projects.map((project) => (
            <Card
              as={project.link ? "a" : "div"}
              href={project.link || undefined}
              target={project.link ? "_blank" : undefined}
              rel={project.link ? "noopener noreferrer" : undefined}
              class="group transition hover:border-accent"
              data-umami-event={project.link ? "project-click" : undefined}
              data-umami-event-project={project.link ? project.name : undefined}
            >
              <div class="flex items-center justify-between gap-4">
                <h4 class="font-display text-base font-semibold text-ink group-hover:text-accent">
                  {project.name}
                </h4>
                {project.stars !== undefined && (
                  <span class="text-xs text-ink-soft">★ {project.stars}</span>
                )}
              </div>
              <p class="mt-3 text-sm text-ink-soft">{project.description}</p>
              <div class="mt-4 flex flex-wrap gap-2">
                {project.tags.map((tag) => (
                  <span class="rounded-full border border-line px-2.5 py-1 text-xs text-ink-soft">
                    {tag}
                  </span>
                ))}
              </div>
            </Card>
          ))}
        </div>
      </div>
    ))}
  </div>
</Section>
