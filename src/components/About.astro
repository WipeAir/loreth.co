---
import { Image } from "astro:assets";
import portrait from "../assets/portrait.jpg";
import { siteData } from "../data/site";
---

<section id="about" class="mx-auto mt-24 max-w-7xl px-4 sm:px-8 md:mt-28">
  <div class="mx-auto grid max-w-2xl grid-cols-1 gap-y-10 lg:max-w-5xl lg:grid-cols-[16rem_1fr] lg:gap-x-12 lg:px-12">
    <div class="flex justify-center lg:justify-start">
      <Image
        src={portrait}
        alt={`Portrait of ${siteData.profile.name}`}
        width={256}
        height={256}
        class="aspect-square w-48 rotate-2 rounded-3xl border border-line object-cover lg:w-64"
      />
    </div>
    <div class="space-y-5 text-base text-ink-soft">
      {siteData.about.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </div>
</section>
