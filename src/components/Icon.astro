---
interface Props {
  id?: string;
  class?: string;
}

const { id, class: className = "h-5 w-5" } = Astro.props;
---

<svg
  id={id}
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  <slot />
</svg>
