---
import { Icon } from "astro-icon/components";
import { siteData } from "../data/site";

const year = new Date().getFullYear();
---

<footer id="contact" class="mx-auto mt-24 max-w-7xl px-4 py-12 sm:px-8 md:mt-28">
  <div class="mx-auto max-w-2xl border-t border-line pt-10 lg:max-w-5xl lg:px-12">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="font-display text-lg font-semibold text-ink">Let's talk</p>
        <p class="mt-1 text-sm text-ink-soft">
          <a
            href={`mailto:${siteData.social.email}`}
            class="text-accent hover:underline"
            data-umami-event="email-click"
            data-umami-event-location="footer"
          >
            {siteData.social.email}
          </a>
        </p>
      </div>
      <div class="flex gap-4 text-sm text-ink-soft">
        <a
          href={siteData.social.github}
          target="_blank"
          rel="noopener noreferrer me"
          class="inline-flex items-center gap-1.5 hover:text-accent"
          data-umami-event="github-click"
          data-umami-event-location="footer"
        >
          <Icon name="tabler:brand-github" class="h-4 w-4" />
          GitHub
        </a>
        <a
          href={siteData.social.linkedin}
          target="_blank"
          rel="noopener noreferrer me"
          class="inline-flex items-center gap-1.5 hover:text-accent"
          data-umami-event="linkedin-click"
          data-umami-event-location="footer"
        >
          <Icon name="tabler:brand-linkedin" class="h-4 w-4" />
          LinkedIn
        </a>
        <a
          href={siteData.social.malt}
          target="_blank"
          rel="noopener noreferrer me"
          class="inline-flex items-center gap-1.5 hover:text-accent"
          data-umami-event="malt-click"
          data-umami-event-location="footer"
        >
          <Icon name="simple-icons:malt" class="h-4 w-4" />
          Malt
        </a>
      </div>
    </div>
    <div class="mt-8 flex flex-col gap-2 text-xs text-ink-soft sm:flex-row sm:items-center sm:justify-between">
      <p>© {year} {siteData.profile.name}. All rights reserved.</p>
      <div class="flex gap-4">
        <a href="/legal/privacy" class="hover:text-accent">Privacy</a>
        <a href="/legal/imprint" class="hover:text-accent">Imprint</a>
        <a href="/llms.txt" class="hover:text-accent">llms.txt</a>
      </div>
    </div>
  </div>
</footer>
