---
import Card from "./Card.astro";
import Section from "./Section.astro";
import SectionHeading from "./SectionHeading.astro";
import { siteData } from "../data/site";

const glowPositions = [
  "-top-16 -right-16",
  "-bottom-16 -left-16",
  "-top-20 right-1/4",
  "-bottom-16 -right-16",
  "-top-16 -left-16",
];
---

<Section id="experience">
  <SectionHeading>
    <h2 class="font-display text-2xl font-semibold tracking-tight text-ink">
      Experience
    </h2>
    <a
      href="/cv.pdf"
      download
      class="shrink-0 rounded-full border border-line px-4 py-2 text-sm font-semibold text-ink transition hover:border-accent hover:text-accent"
      data-umami-event="cv-download"
    >
      Download CV
    </a>
  </SectionHeading>
  <ol class="mt-8 space-y-6">
    {siteData.experience.map((role, i) => (
      <Card as="li">
        <div
          class={`pointer-events-none absolute ${glowPositions[i % glowPositions.length]} h-40 w-40 rounded-full bg-accent/10 blur-3xl`}
          aria-hidden="true"
        >
        </div>
        <div class="relative">
          <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
            <p class="font-display text-lg font-semibold text-ink">{role.company}</p>
            <p class="text-sm text-ink-soft">{role.dateRange}</p>
          </div>
          <p class="mt-1 text-sm text-accent">{role.role}</p>
          <ul class="mt-4 list-disc space-y-2 pl-5 text-sm text-ink-soft">
            {role.bullets.map((bullet) => <li>{bullet}</li>)}
          </ul>
        </div>
      </Card>
    ))}
  </ol>
</Section>
